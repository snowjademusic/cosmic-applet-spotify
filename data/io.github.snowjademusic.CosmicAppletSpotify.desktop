[Desktop Entry]
Type=Application
Name=Spotify Now Playing
Comment=Show the currently playing Spotify track in the COSMIC panel
Exec=cosmic-applet-spotify
Icon=io.github.snowjademusic.CosmicAppletSpotify
Terminal=false
Categories=AudioVideo;Player;
Keywords=Spotify;MPRIS;Now Playing;COSMIC;Applet;
X-CosmicApplet=true
NoDisplay=true